		<Agency>
			<LongName xml:lang="es">DIAN (Dirección de Impuestos y Aduanas Nacionales)</LongName>
			<Identifier>195</Identifier>
		</Agency>
	</Identification>
	<ColumnSet>
		<Column Id="name" Use="required">
			<ShortName>Nombre</ShortName>
			<Data Type="normalizedString"/>
		</Column>
		<Column Id="description" Use="required">
			<ShortName>Descripción</ShortName>
			<Data Type="normalizedString"/>
		</Column>
		<Key Id="codeKey">
			<ShortName>CodeKey</ShortName>
			<ColumnRef Ref="code"/>
		</Key>
	</ColumnSet>
	<SimpleCodeList>
		<Row>
			<Value ColumnRef="name">
				<SimpleValue>cac:InvoiceDocumentReference</SimpleValue>
			</Value>
			<Value ColumnRef="description">
				<SimpleValue>Invoice - Statement</SimpleValue>
			</Value>
		</Row>
		<Row>
			<Value ColumnRef="name">
				<SimpleValue>cac:CreditNoteDocumentReference</SimpleValue>
			</Value>
			<Value ColumnRef="description">
				<SimpleValue>CreditNote</SimpleValue>
			</Value>
		</Row>
		<Row>
			<Value ColumnRef="name">
				<SimpleValue>cac:AdditionalDocumentReference</SimpleValue>
			</Value>
			<Value ColumnRef="description">
				<SimpleValue>Factura en Papel - Pos Actual</SimpleValue>
			</Value>
		</Row>
		<Row>
			<Value ColumnRef="name">
				<SimpleValue>cac:BillingReferenceLine</SimpleValue>
			</Value>
			<Value ColumnRef="description">
				<SimpleValue>Valores de cada grupo</SimpleValue>
			</Value>
		</Row>
	</SimpleCodeList>
</gc:CodeList>