<?xml version="1.0" encoding="UTF-8"?>
<gc:CodeList xmlns:gc="http://docs.oasis-open.org/codelist/ns/genericode/1.0/">
	<Identification>
		<ShortName>Referencia</ShortName>
		<LongName xml:lang="es">Tipo de usuario</LongName>
		<Version>1</Version>
