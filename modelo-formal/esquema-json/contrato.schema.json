{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ris-facturacion-colombia/esquema/contrato.schema.json",
  "title": "Contrato (tarifa × convenio)",
  "description": "Cuelga de un convenio. Define la tarifa (estudios + insumos con precio), cobertura/modalidad, vigencia y el recaudo del paciente. AQUÍ vive el precio.",
  "type": "object",
  "required": ["nombre", "convId", "cob", "mod", "desde", "hasta", "tarifa", "recaudo"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^CT[0-9]+$" },
    "nombre": { "type": "string", "minLength": 1 },
    "convId": { "type": "string", "pattern": "^CV[0-9]+$", "description": "FK → convenio" },
    "cob": { "type": "string", "enum": ["01","02","03","04","05","06","07","08","09","10","11","12","13","14","15","16","17"], "$comment": "enums.json → COBERTURA" },
    "mod": { "type": "string", "enum": ["01","02","03","04"], "$comment": "enums.json → MODALIDAD_PAGO" },
    "desde": { "type": "string", "format": "date" },
    "hasta": { "type": "string", "format": "date" },
    "tarifa": {
      "type": "array",
      "minItems": 1,
      "description": "Estudios tarifados. Regla CONT.tarifa: mínimo 1.",
      "items": {
        "type": "object",
        "required": ["c", "n", "p"],
        "properties": {
          "c": { "type": "string", "description": "código CUPS (catálogo real)" },
          "n": { "type": "string", "description": "nombre del estudio" },
          "p": { "type": "number", "exclusiveMinimum": 0, "description": "precio negociado al pagador" }
        }
      }
    },
    "insumos": {
      "type": "array",
      "description": "Insumos tarifados (opcional): medicamento/contraste (CUM-IUM) o dispositivo (UDI).",
      "items": {
        "type": "object",
        "required": ["c", "n", "tipo", "p"],
        "properties": {
          "c": { "type": "string" },
          "n": { "type": "string" },
          "tipo": { "type": "string", "enum": ["medicamento", "dispositivo"] },
          "p": { "type": "number", "exclusiveMinimum": 0 }
        }
      }
    },
    "recaudo": {
      "type": "object",
      "description": "Guarda AMBAS figuras (copago y cuota moderadora) por nivel, todas OPCIONALES. Cuál se APLICA en la orden lo determina el tipo de usuario del paciente (mapa RECAUDO_TU en reglas.dmn.json). Rediseño: antes el 'concepto' (01/02/05) vivía aquí; ahora se deriva del paciente.",
      "properties": {
        "copago": {
          "type": "object",
          "description": "Copago = % (0–100) por nivel + tope por evento. Opcional; si se digita, valida CONT.copagoRango.",
          "properties": {
            "n1": { "type": "string", "description": "% nivel 1 (0–100)" },
            "n2": { "type": "string", "description": "% nivel 2 (0–100)" },
            "n3": { "type": "string", "description": "% nivel 3 (0–100)" },
            "tope": { "type": "string", "description": "tope por evento ($)" }
          }
        },
        "cuota": {
          "type": "object",
          "description": "Cuota moderadora = valor fijo ($) por nivel. Opcional.",
          "properties": {
            "n1": { "type": "string", "description": "$ fijo nivel 1" },
            "n2": { "type": "string", "description": "$ fijo nivel 2" },
            "n3": { "type": "string", "description": "$ fijo nivel 3" }
          }
        }
      }
    }
  }
}
