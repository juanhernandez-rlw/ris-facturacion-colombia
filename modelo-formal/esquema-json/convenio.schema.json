{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ris-facturacion-colombia/esquema/convenio.schema.json",
  "title": "Convenio (maestro del pagador)",
  "description": "Maestro del pagador y sus reglas. NO lleva precio (eso es del contrato). Los códigos permitidos viven, con sus etiquetas, en enums.json (fuente autoritativa).",
  "type": "object",
  "required": ["nombre", "tipoId", "nid", "tipoUsuarios", "forma", "medio", "iva", "reqAut", "reqMipres", "reqSiras"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^CV[0-9]+$" },
    "nombre": { "type": "string", "minLength": 1 },
    "tipoId": { "type": "string", "enum": ["NI", "CC", "CE"], "$comment": "enums.json → TIPO_ID_PAGADOR" },
    "nid": { "type": "string", "minLength": 1, "description": "NIT / número de identificación del pagador" },
    "razon": { "type": "string", "description": "Razón social" },
    "tipoUsuarios": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["01","02","03","04","05","06","07","08","09","10","11","12","13"] },
      "description": "CONJUNTO de tipos de usuario que atiende el convenio (multi-selección). enums.json → TIPO_USUARIO. Regla CONV.tiposUsuario: mínimo 1."
    },
    "forma": { "type": "string", "enum": ["1", "2"], "$comment": "enums.json → FORMAPAGO (DIAN)" },
    "medio": { "type": "string", "enum": ["10","47","42","48","49","20","1"], "$comment": "enums.json → MEDIOPAGO (DIAN)" },
    "plazo": { "type": "string", "pattern": "^[0-9]+$", "description": "Plazo en días" },
    "iva": { "type": "string", "enum": ["NO", "SI"], "$comment": "enums.json → IVAOPC" },
    "ret": { "type": "string", "description": "Retención renta (%) — valor de demo en el prototipo" },
    "reqAut": { "type": "boolean", "description": "¿Exige autorización previa? Activa la casilla condicional 'Código de autorización' en la orden." },
    "reqMipres": { "type": "boolean", "description": "¿Exige MIPRES?" },
    "reqSiras": { "type": "boolean", "description": "¿Exige SIRAS (SOAT)?" }
  }
}
